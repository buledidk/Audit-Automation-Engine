# ═══════════════════════════════════════════════════════════════════
# AuditEngine Environment Configuration
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════

# SUPABASE (Phase 2 - Database)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AWS S3 (Phase 2 - File Storage)
VITE_AWS_REGION=eu-west-2
VITE_AWS_ACCESS_KEY_ID=your-access-key
VITE_AWS_SECRET_ACCESS_KEY=your-secret-key
VITE_AWS_S3_BUCKET=audit-engine-files

# CLAUDE API (Phase 3 - AI Integration)
VITE_CLAUDE_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY_HERE

# HEAVY AUTOMATION (Optional — Claude Opus 4.6 deep audit workflows)
HEAVY_AUTOMATION_DAILY_BUDGET=50
HEAVY_AUTOMATION_MAX_CONCURRENT=5
HEAVY_AUTOMATION_TIMEOUT_MS=120000
HEAVY_AUTOMATION_ENABLED=true

# ACCURACY ENHANCEMENT ENGINE (Optional — ISA 330/500/520/530/540 accuracy verification)
ENABLE_ACCURACY_ENHANCEMENTS=true

# FINANCIAL STATEMENT ANALYSIS AGENT (Optional — FS extraction, reconciliation, compliance, risk)
ENABLE_FS_ANALYSIS=true

# APPLICATION
VITE_APP_ENV=development
VITE_APP_NAME=AuditEngine
VITE_APP_VERSION=1.0.0
