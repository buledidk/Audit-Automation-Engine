{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "name": "auditengine",
  "github": {
    "enabled": true,
    "autoAlias": true
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
